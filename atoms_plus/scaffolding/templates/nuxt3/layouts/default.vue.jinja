<script setup lang="ts">
{% if use_dark_mode %}
{% raw %}const colorMode = useColorMode()
const toggleDark = () => {
  colorMode.preference = colorMode.value === 'dark' ? 'light' : 'dark'
}{% endraw %}
{% endif %}
</script>

<template>
{% if ui_library == "tailwind" %}
  <div class="min-h-screen bg-white dark:bg-gray-950">
