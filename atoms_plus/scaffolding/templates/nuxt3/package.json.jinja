{
  "name": "{{ project_name }}",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "{{ description }}",
  "author": "{{ author }}",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare"{% if use_eslint %},
    "lint": "eslint ."{% endif %}{% if use_testing %},
    "test": "vitest"{% endif %}
  },
  "dependencies": {
    "nuxt": "^3.13.2",
    "vue": "^3.5.12",
    "vue-router": "^4.4.5"{% if use_supabase %},
    "@nuxtjs/supabase": "^1.4.0"{% endif %}{% if ui_library == "primevue" %},
    "@primevue/nuxt-module": "^4.1.0",
    "primevue": "^4.1.0",
    "primeicons": "^7.0.0"{% endif %}
  },
  "devDependencies": {
    "@nuxt/devtools": "^1.5.2"{% if use_typescript %},
    "typescript": "^5.6.3"{% endif %}{% if ui_library == "tailwind" %},
    "@nuxtjs/tailwindcss": "^6.12.1"{% endif %}{% if use_eslint %},
    "@nuxt/eslint-config": "^0.6.0",
    "eslint": "^9.13.0"{% endif %}{% if use_testing %},
    "@nuxt/test-utils": "^3.14.3",
    "vitest": "^2.1.4"{% endif %}
  }
}

