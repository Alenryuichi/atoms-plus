{
  "name": "{{ project_name }}",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "{{ description }}",
  "author": "{{ author }}",
  "scripts": {
    "dev": "vite",
    "build": "{% if use_typescript %}vue-tsc -b && {% endif %}vite build",
    "preview": "vite preview"{% if use_eslint %},
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix"{% endif %}{% if use_testing %},
    "test": "vitest",
    "test:ui": "vitest --ui"{% endif %}
  },
  "dependencies": {
    "vue": "^3.5.12",
    "vue-router": "^4.4.5",
    "pinia": "^2.2.4"{% if use_supabase %},
    "@supabase/supabase-js": "^2.45.0"{% endif %}{% if use_i18n %},
    "vue-i18n": "^9.14.1"{% endif %}{% if ui_library == "primevue" %},
    "primevue": "^4.1.0",
    "primeicons": "^7.0.0"{% endif %}
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.4",
    "vite": "^5.4.10"{% if use_typescript %},
    "typescript": "^5.6.3",
    "vue-tsc": "^2.1.8"{% endif %}{% if ui_library == "tailwind" or ui_library == "shadcn" %},
    "tailwindcss": "^3.4.14",
    "postcss": "^8.4.47",
    "autoprefixer": "^10.4.20"{% endif %}{% if use_eslint %},
    "eslint": "^9.13.0",
    "eslint-plugin-vue": "^9.29.0",
    "@vue/eslint-config-typescript": "^14.1.1"{% endif %}{% if use_testing %},
    "vitest": "^2.1.4",
    "@vitest/ui": "^2.1.4",
    "@vue/test-utils": "^2.4.6"{% endif %}
  }
}

