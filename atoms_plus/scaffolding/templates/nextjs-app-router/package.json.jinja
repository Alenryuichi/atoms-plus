{
  "name": "{{ project_name }}",
  "version": "0.1.0",
  "private": true,
  "description": "{{ description }}",
  "author": "{{ author }}",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start"{% if use_eslint %},
    "lint": "next lint"{% endif %}{% if use_testing %},
    "test": "vitest",
    "test:ui": "vitest --ui"{% endif %}
  },
  "dependencies": {
    "next": "^14.2.16",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"{% if use_supabase %},
    "@supabase/supabase-js": "^2.45.0",
    "@supabase/ssr": "^0.5.1"{% endif %}{% if use_i18n %},
    "next-intl": "^3.19.0"{% endif %}
  },
  "devDependencies": {
    "@types/node": "^22.8.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1"{% if use_typescript %},
    "typescript": "^5.6.3"{% endif %}{% if ui_library == "tailwind" or ui_library == "shadcn" %},
    "tailwindcss": "^3.4.14",
    "postcss": "^8.4.47",
    "autoprefixer": "^10.4.20"{% endif %}{% if use_eslint %},
    "eslint": "^9.13.0",
    "eslint-config-next": "^14.2.16"{% endif %}{% if use_testing %},
    "vitest": "^2.1.4",
    "@vitest/ui": "^2.1.4",
    "@testing-library/react": "^16.0.1"{% endif %}{% if ui_library == "shadcn" %},
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4",
    "lucide-react": "^0.454.0"{% endif %}
  }
}

